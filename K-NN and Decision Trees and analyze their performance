      "cell_type": "code",
      "source": [
        "# Prepare Data for Modeling\n",
        "\n",
        "X = df.drop('target', axis=1)\n",
        "y = df['target']\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y, test_size=0.3, random_state=42, stratify=y\n",
        ")"
      ],
      "metadata": {
        "id": "-cGjXWmPZilg"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Feature Scaling (Important for KNN)\n",
        "\n",
        "scaler = StandardScaler()\n",
        "\n",
        "X_train_scaled = scaler.fit_transform(X_train)\n",
        "X_test_scaled = scaler.transform(X_test)"
      ],
      "metadata": {
        "id": "2dzvo43TZmCj"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# K-Nearest Neighbors Model\n",
        "\n",
        "knn = KNeighborsClassifier(n_neighbors=5)\n",
        "\n",
        "knn.fit(X_train_scaled, y_train)\n",
        "\n",
        "y_pred_knn = knn.predict(X_test_scaled)\n",
        "y_prob_knn = knn.predict_proba(X_test_scaled)[:, 1]"
      ],
      "metadata": {
        "id": "Uk__TJknZp-M"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Decision Tree Model\n",
        "\n",
        "dt = DecisionTreeClassifier(max_depth=4, random_state=42)\n",
        "\n",
        "dt.fit(X_train, y_train)\n",
        "\n",
        "y_pred_dt = dt.predict(X_test)\n",
        "y_prob_dt = dt.predict_proba(X_test)[:, 1]"
      ],
      "metadata": {
        "id": "cJWg_AY3ZtKy"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Evaluation Function\n",
        "\n",
        "def evaluate_model(y_test, y_pred, y_prob, model_name):\n",
        "    print(f\"\\n================ {model_name} Performance ================\")\n",
        "\n",
        "    print(\"Accuracy :\", accuracy_score(y_test, y_pred))\n",
        "    print(\"Precision:\", precision_score(y_test, y_pred))\n",
        "    print(\"Recall   :\", recall_score(y_test, y_pred))\n",
        "    print(\"F1 Score :\", f1_score(y_test, y_pred))\n",
        "    print(\"ROC-AUC  :\", roc_auc_score(y_test, y_prob))\n",
        "\n",
        "    print(\"\\nConfusion Matrix:\\n\", confusion_matrix(y_test, y_pred))\n",
        "\n",
        "    print(\"\\nClassification Report:\\n\", classification_report(y_test, y_pred))\n"
      ],
      "metadata": {
        "id": "I321Cl-3ZxSN"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Evaluate Both Models\n",
        "\n",
        "evaluate_model(y_test, y_pred_knn, y_prob_knn, \"KNN\")\n",
        "evaluate_model(y_test, y_pred_dt, y_prob_dt, \"Decision Tree\")\n"
      ],
